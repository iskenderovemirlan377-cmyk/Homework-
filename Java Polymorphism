public class Main {
    public static void main(String[] args) {
        Shape s = new Circle();   // Polymorphism
        s.draw();                 // Calls overridden method
    }
}

public class Circle extends Shape {

    @Override
    public void draw() {
        System.out.println("Drawing a circle");
    }
}

public class Shape {
    public void draw() {
        System.out.println("Drawing a shape");
    }
}
